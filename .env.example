# ──────────────────────────────────────────────────────────
# Video Pipeline - Local Environment Variables Configuration
# ──────────────────────────────────────────────────────────

# [CRITICAL] Anthropic API Key for 3-Round Fact-Checking & Claude Sonnet script generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [Optional] Market Data Collector APIs
FINNHUB_API_KEY=d951j4pr01qq8ms6uaa0d951j4pr01qq8ms6uaag
FRED_API_KEY=
DART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# [Optional] Premium Voice Narration
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# Eleven v3 enables Korean language_code and IPA-capable pronunciation dictionaries.
ELEVENLABS_TTS_MODEL=eleven_v3

# [Optional] Premium Kling AI Motion Video Generation
KLING_API_KEY=

# [Optional] Gemini API Key
GEMINI_API_KEY=
# Immediate video jobs use synchronous Pro generation. Batch is reserved for
# explicitly selected economy rendering. It is never an interactive fallback.
GEMINI_PRO_BATCH_ENABLED=false
GEMINI_PRO_BATCH_FALLBACK_ENABLED=false
# Priority requires Gemini API Tier 2/3. Keep standard for a Tier 1 account.
GEMINI_SERVICE_TIER=standard

# Korean ElevenLabs narration: 1.25x, based on measured
# narration characters (not visual-prompt text).
TTS_SPEED=1.25
CHARS_PER_MINUTE=280

# Direct Gemini Pro 2K reliability. Batch remains disabled for interactive jobs.
GEMINI_PRO_MAX_ATTEMPTS=5
GEMINI_PRO_RETRY_BASE_SECONDS=10
GEMINI_PRO_REQUEST_DELAY_SECONDS=3
