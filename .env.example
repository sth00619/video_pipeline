# ──────────────────────────────────────────────────────────
# Video Pipeline - Local Environment Variables Configuration
# ──────────────────────────────────────────────────────────

# [CRITICAL] Anthropic API Key for 3-Round Fact-Checking & Claude Sonnet script generation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [Optional] YouTube Data API v3 key for keyword/video evidence search
YOUTUBE_API_KEY=

# [Optional] Market Data Collector APIs
FINNHUB_API_KEY=d951j4pr01qq8ms6uaa0d951j4pr01qq8ms6uaag
FRED_API_KEY=
DART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# [Optional] Premium Voice Narration
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=dlKJ5VptCbYxal4doUO5
# Eleven v3 enables Korean language_code and IPA-capable pronunciation dictionaries.
ELEVENLABS_TTS_MODEL=eleven_v3

# [Optional] Premium Kling AI Motion Video Generation
KLING_API_KEY=

# [Optional] Gemini API Key
GEMINI_API_KEY=
# Immediate video jobs use synchronous Pro generation. Batch is reserved for
# explicitly selected economy rendering. It is never an interactive fallback.
GEMINI_PRO_BATCH_ENABLED=false
GEMINI_PRO_BATCH_FALLBACK_ENABLED=false
# Priority requires Gemini API Tier 2/3. Keep standard for a Tier 1 account.
GEMINI_SERVICE_TIER=standard

# Korean ElevenLabs narration: 1.25x, based on measured
# narration characters (not visual-prompt text).
TTS_SPEED=1.0
TTS_SENTENCE_PAUSE_MS=350
TTS_PARAGRAPH_PAUSE_MS=400
CHARS_PER_MINUTE=400

# Direct Gemini Pro 2K reliability. Batch remains disabled for interactive jobs.
GEMINI_PRO_MAX_ATTEMPTS=5
GEMINI_PRO_RETRY_BASE_SECONDS=10
GEMINI_PRO_REQUEST_DELAY_SECONDS=3
GEMINI_PARALLEL_ENABLED=true
GEMINI_MAX_CONCURRENCY=8
GEMINI_RETRY_MAX=3
GEMINI_RPM_SOFT_CAP=60
GEMINI_ADAPTIVE_BACKOFF_ENABLED=true
LONGFORM_SCENE_MAX_WORKERS=2
# Long-form default: preserve the 2D art direction while using Pro/2K only
# for anchor scenes.  The remaining scenes use Flash/1K in the same style,
# so a 20-minute job can stay within an operational 40-minute target.
IMAGE_QUALITY_TIER=pro
PRO_IMAGE_MAX_SCENES=48
# Replace these placeholder rates with the current AI Studio/Fal console rates
# before a production run. The preflight includes its own retry buffer.
IMG_COST_FLASH_1K_USD=0.045
IMG_COST_PRO_2K_USD=0.134
KLING_COST_PER_CLIP_USD=0.45
USD_KRW=1400
MAX_BUDGET_PER_VIDEO_KRW=40000
BUDGET_RETRY_BUFFER_PCT=10
INTRO_KLING_MAX_CLIPS=11
ANTHROPIC_PROMPT_CACHE_ENABLED=true
ANTHROPIC_PROMPT_CACHE_TTL=5m
