# Railway 환경변수 설정 가이드
# 이 파일을 복사하여 Railway 대시보드의 각 서비스 Variables 탭에 입력하세요.
# 절대 이 파일에 실제 API Key를 입력하지 마세요.

# ===== spring-app 서비스 환경변수 =====
SPRING_DATASOURCE_URL=jdbc:postgresql://${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}
SPRING_DATASOURCE_USERNAME=${{Postgres.PGUSER}}
SPRING_DATASOURCE_PASSWORD=${{Postgres.PGPASSWORD}}
SPRING_DATA_REDIS_HOST=${{Redis.REDIS_HOST}}
SPRING_DATA_REDIS_PORT=${{Redis.REDIS_PORT}}
APP_SECRET_KEY=video-pipeline-jwt-secret-key-must-be-32chars-minimum-2026!!
FASTAPI_URL=https://your-fastapi-service.railway.app
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=500MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=500MB
SERVER_PORT=8080

# ===== fastapi-workers 서비스 환경변수 =====
APP_MODE=production
REDIS_HOST=${{Redis.REDIS_HOST}}
REDIS_PORT=${{Redis.REDIS_PORT}}
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxx  # 실제 키로 교체
FINNHUB_API_KEY=your_finnhub_key
FRED_API_KEY=your_fred_key
DART_API_KEY=your_dart_key
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ===== frontend 서비스 환경변수 =====
BACKEND_URL=https://your-spring-app.railway.app
